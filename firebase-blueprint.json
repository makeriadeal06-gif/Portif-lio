{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "Portfolio project data",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "type": { "type": "string", "enum": ["3D", "WEB"] },
        "image": { "type": "string", "format": "uri" },
        "model3d": { "type": "string", "format": "uri" },
        "modelFormat": { "type": "string", "enum": ["glb", "stl"] },
        "projectUrl": { "type": "string", "format": "uri" },
        "previewType": { "type": "string", "enum": ["image", "iframe"] },
        "visible": { "type": "boolean" },
        "order": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "type", "visible", "createdAt"]
    },
    "Experiment": {
      "title": "Experiment",
      "description": "Lab experiments or personal experiences",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "details": { "type": "string" },
        "type": { "type": "string", "enum": ["LAB", "EXPERIENCE"] },
        "dateRange": { "type": "string" },
        "location": { "type": "string" },
        "tech": { "type": "array", "items": { "type": "string" } },
        "visible": { "type": "boolean" },
        "order": { "type": "integer" },
        "status": { "type": "string" },
        "projectUrl": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "type", "visible", "createdAt"]
    }
  },
  "firestore": {
    "projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of projects"
    },
    "experiments/{experimentId}": {
      "schema": "Experiment",
      "description": "Collection of experiments and experiences"
    }
  }
}
